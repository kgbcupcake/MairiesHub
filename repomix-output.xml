<file path="Views/ServicesView.axaml">
<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:MairiesHub.ViewModels"
             xmlns:models="using:MairiesHub.Models"
             xmlns:conv="using:MairiesHub.Converters"
             x:Class="MairiesHub.Views.ServicesView"
             x:DataType="vm:ServicesViewModel"
             Background="#0a0d14">

    <UserControl.Resources>
        <conv:CyberpunkStateConverter x:Key="CyberpunkStateConverter" />
    </UserControl.Resources>

    <UserControl.Styles>
        <Style Selector="Border.ServiceCard">
            <Setter Property="Background" Value="#0f1623" />
            <Setter Property="BorderBrush" Value="#1e3a5f" />
            <Setter Property="Transitions">
                <Transitions>
                    <BrushTransition Property="Background" Duration="0:0:0.15" />
                    <BrushTransition Property="BorderBrush" Duration="0:0:0.15" />
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="Border.ServiceCard:pointerover">
            <Setter Property="BorderBrush" Value="#9922d3ee" />
            <Setter Property="Background" Value="#111520" />
        </Style>
        <Style Selector="Button.CyberBtn">
            <Setter Property="FontFamily" Value="Courier New,monospace" />
            <Setter Property="FontSize" Value="10" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Padding" Value="8,3" />
            <Setter Property="CornerRadius" Value="2" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>
        <Style Selector="Button.StartBtn">
            <Setter Property="Background" Value="#0d3d2a" />
            <Setter Property="Foreground" Value="#22d3ee" />
            <Setter Property="BorderBrush" Value="#22d3ee" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>
        <Style Selector="Button.StartBtn:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#22d3ee" />
            <Setter Property="TextElement.Foreground" Value="#0a0d14" />
        </Style>
        <Style Selector="Button.StopBtn">
            <Setter Property="Background" Value="#3d0d0d" />
            <Setter Property="Foreground" Value="#fb923c" />
            <Setter Property="BorderBrush" Value="#fb923c" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>
        <Style Selector="Button.StopBtn:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#fb923c" />
            <Setter Property="TextElement.Foreground" Value="#0a0d14" />
        </Style>
    </UserControl.Styles>

    <Grid RowDefinitions="Auto,Auto,*" Margin="20,16,20,16">

        <!-- Header -->
        <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Margin="0,0,0,10">
            <StackPanel Orientation="Vertical" Spacing="0" VerticalAlignment="Center">
                <TextBlock Text="SERVICES"
                           FontFamily="Rajdhani,monospace"
                           FontSize="28"
                           FontWeight="Bold"
                           Foreground="#e2e8f0"
                           LetterSpacing="4" />
                <Border Height="1.5"
                        Background="#22d3ee"
                        HorizontalAlignment="Left"
                        Width="120"
                        Margin="0,3,0,0" />
            </StackPanel>

            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center"
                            IsVisible="{Binding IsLoading}">
                    <Ellipse Width="6" Height="6" Fill="#22d3ee" />
                    <TextBlock Text="Refreshing"
                               FontFamily="Courier New,monospace"
                               FontSize="11"
                               Foreground="#475569"
                               VerticalAlignment="Center" />
                </StackPanel>
                <Border CornerRadius="2"
                        Background="#22d3ee"
                        Padding="6,2"
                        VerticalAlignment="Center">
                    <TextBlock Text="{Binding StatusMessage}"
                               FontSize="11"
                               FontWeight="SemiBold"
                               Foreground="#0a0d14" />
                </Border>
            </StackPanel>
        </Grid>

        <!-- Horizontal rule -->
        <Border Grid.Row="1"
                Height="1"
                Background="#4d22d3ee"
                Margin="0,0,0,12" />

        <!-- Card grid -->
        <Grid Grid.Row="2">
            <ScrollViewer VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <ItemsControl ItemsSource="{Binding Services}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="models:ServiceInfo">
                            <Border Classes="ServiceCard"
                                    MinWidth="200"
                                    MaxWidth="260"
                                    Margin="6"
                                    CornerRadius="4"
                                    Padding="12"
                                    BorderThickness="1">
                                <StackPanel Spacing="6">

                                    <!-- Name + status dot -->
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <Ellipse Width="10" Height="10"
                                                 VerticalAlignment="Center"
                                                 Fill="{Binding Running, Converter={StaticResource CyberpunkStateConverter}}" />
                                        <TextBlock Text="{Binding Name}"
                                                   FontFamily="Rajdhani,monospace"
                                                   FontSize="13"
                                                   FontWeight="SemiBold"
                                                   Foreground="#e2e8f0"
                                                   TextTrimming="CharacterEllipsis"
                                                   VerticalAlignment="Center" />
                                    </StackPanel>

                                    <!-- Description -->
                                    <TextBlock Text="{Binding Description}"
                                               FontFamily="Courier New,monospace"
                                               FontSize="11"
                                               Foreground="#475569"
                                               Margin="16,0,0,0"
                                               TextTrimming="CharacterEllipsis"
                                               TextWrapping="NoWrap" />

                                    <!-- Port -->
                                    <TextBlock Text="{Binding PortLabel}"
                                               FontFamily="Courier New,monospace"
                                               FontSize="10"
                                               Foreground="#22d3ee"
                                               Margin="16,0,0,0"
                                               IsVisible="{Binding PortLabel, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                               TextTrimming="CharacterEllipsis" />

                                    <!-- Status badge -->
                                    <StackPanel Orientation="Horizontal" Spacing="4" Margin="16,0,0,0">
                                        <TextBlock Text="&#x25CF;"
                                                   FontSize="10"
                                                   VerticalAlignment="Center"
                                                   Foreground="{Binding Running, Converter={StaticResource CyberpunkStateConverter}}" />
                                        <TextBlock Text="running"
                                                   FontFamily="Courier New,monospace"
                                                   FontSize="10"
                                                   VerticalAlignment="Center"
                                                   Foreground="#22d3ee"
                                                   IsVisible="{Binding Running}" />
                                        <TextBlock Text="stopped"
                                                   FontFamily="Courier New,monospace"
                                                   FontSize="10"
                                                   VerticalAlignment="Center"
                                                   Foreground="#7f1d1d"
                                                   IsVisible="{Binding !Running}" />
                                    </StackPanel>

                                    <!-- Control buttons -->
                                    <StackPanel Orientation="Horizontal" Spacing="4" Margin="16,4,0,0"
                                                IsVisible="{Binding Controllable}">
                                        <Button Classes="CyberBtn StartBtn"
                                                Content="START"
                                                Command="{Binding DataContext.StartServiceCommand,
                                                          RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding Name}"
                                                IsVisible="{Binding !Running}" />
                                        <Button Classes="CyberBtn StopBtn"
                                                Content="STOP"
                                                Command="{Binding DataContext.StopServiceCommand,
                                                          RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding Name}"
                                                IsVisible="{Binding Running}" />
                                    </StackPanel>

                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <!-- Empty state -->
            <TextBlock Text="No services found"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       Foreground="#475569"
                       FontSize="14"
                       IsVisible="{Binding !Services.Count}" />
        </Grid>

    </Grid>
</UserControl>
</file>

