<file path="Views/MainWindow.axaml">
<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:MairiesHub.ViewModels"
        xmlns:controls="using:MairiesHub.Controls"
        xmlns:conv="using:MairiesHub.Converters"
        x:Class="MairiesHub.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="MairiesHub"
        Width="1200" Height="760"
        MinWidth="900" MinHeight="600"
        Background="#0d0d14"
        ExtendClientAreaToDecorationsHint="False">

    <Grid RowDefinitions="56,*">

        <!-- ══════════════════════  TOP STATS BAR  ══════════════════════ -->
        <Border Grid.Row="0"
                Background="#13131c"
                BorderBrush="#1e1e2d"
                BorderThickness="0,0,0,1">
            <Grid ColumnDefinitions="Auto,*,Auto">

                <!-- App title -->
                <StackPanel Grid.Column="0"
                            Orientation="Horizontal"
                            VerticalAlignment="Center"
                            Margin="18,0,0,0"
                            Spacing="8">
                    <Ellipse Width="8" Height="8" Fill="#00bcd4" />
                    <TextBlock Text="MairiesHub"
                               FontSize="15"
                               FontWeight="SemiBold"
                               Foreground="#00bcd4"
                               VerticalAlignment="Center" />
                </StackPanel>

                <!-- ECG + live stats (centred) -->
                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Spacing="24">

                    <!-- CPU -->
                    <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                        <controls:EcgHeartbeatControl x:Name="CpuHeartbeat"
                                                      Width="90" Height="32"
                                                      SampleCapacity="60" />
                        <StackPanel VerticalAlignment="Center" Spacing="1">
                            <TextBlock Text="CPU" Classes="SectionHeader" />
                            <TextBlock FontSize="13" Foreground="#e0e0e0">
                                <TextBlock.Text>
                                    <Binding Path="SystemVm.CpuPercent" StringFormat="{}{0:F0}%" />
                                </TextBlock.Text>
                            </TextBlock>
                        </StackPanel>
                    </StackPanel>

                    <!-- Separator -->
                    <Rectangle Width="1" Height="28" Fill="#252535" />

                    <!-- RAM -->
                    <StackPanel VerticalAlignment="Center" Spacing="1">
                        <TextBlock Text="RAM" Classes="SectionHeader" />
                        <StackPanel Orientation="Horizontal" Spacing="4">
                            <TextBlock FontSize="13" Foreground="#e0e0e0">
                                <TextBlock.Text>
                                    <Binding Path="SystemVm.RamUsedGb" StringFormat="{}{0:F1}" />
                                </TextBlock.Text>
                            </TextBlock>
                            <TextBlock Classes="Muted" VerticalAlignment="Bottom">/</TextBlock>
                            <TextBlock Classes="Muted" VerticalAlignment="Bottom">
                                <TextBlock.Text>
                                    <Binding Path="SystemVm.RamTotalGb" StringFormat="{}{0:F0} GB" />
                                </TextBlock.Text>
                            </TextBlock>
                        </StackPanel>
                    </StackPanel>

                    <!-- Separator -->
                    <Rectangle Width="1" Height="28" Fill="#252535" />

                    <!-- Disk -->
                    <StackPanel VerticalAlignment="Center" Spacing="1">
                        <TextBlock Text="DISK" Classes="SectionHeader" />
                        <StackPanel Orientation="Horizontal" Spacing="4">
                            <TextBlock FontSize="13" Foreground="#e0e0e0">
                                <TextBlock.Text>
                                    <Binding Path="SystemVm.DiskUsedGb" StringFormat="{}{0:F0}" />
                                </TextBlock.Text>
                            </TextBlock>
                            <TextBlock Classes="Muted" VerticalAlignment="Bottom">/</TextBlock>
                            <TextBlock Classes="Muted" VerticalAlignment="Bottom">
                                <TextBlock.Text>
                                    <Binding Path="SystemVm.DiskTotalGb" StringFormat="{}{0:F0} GB" />
                                </TextBlock.Text>
                            </TextBlock>
                        </StackPanel>
                    </StackPanel>

                    <!-- Separator -->
                    <Rectangle Width="1" Height="28" Fill="#252535" />

                    <!-- Uptime -->
                    <StackPanel VerticalAlignment="Center" Spacing="1">
                        <TextBlock Text="UPTIME" Classes="SectionHeader" />
                        <StackPanel Orientation="Horizontal" Spacing="2">
                            <TextBlock FontSize="13" Foreground="#e0e0e0">
                                <TextBlock.Text>
                                    <Binding Path="SystemVm.UptimeDays" StringFormat="{}{0}d" />
                                </TextBlock.Text>
                            </TextBlock>
                            <TextBlock FontSize="13" Foreground="#757575" Margin="2,0,0,0">
                                <TextBlock.Text>
                                    <Binding Path="SystemVm.UptimeHours" StringFormat="{}{0}h" />
                                </TextBlock.Text>
                            </TextBlock>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>

                <!-- Connection indicator -->
                <StackPanel Grid.Column="2"
                            Orientation="Horizontal"
                            VerticalAlignment="Center"
                            Margin="0,0,16,0"
                            Spacing="6">
                    <Ellipse Width="7" Height="7"
                             Fill="{Binding SystemVm.IsConnected,
                                   Converter={x:Static conv:StateToColorConverter.Instance},
                                   ConverterParameter=running}" />
                    <TextBlock Text="{Binding SystemVm.IsConnected,
                                     Converter={x:Static conv:StateToColorConverter.Instance}}"
                               Classes="Muted"
                               IsVisible="False" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- ══════════════════════  SIDEBAR + CONTENT  ══════════════════════ -->
        <Grid Grid.Row="1" ColumnDefinitions="160,*">

            <!-- ── Left sidebar ── -->
            <Border Grid.Column="0"
                    Background="#0f0f18"
                    BorderBrush="#1e1e2d"
                    BorderThickness="0,0,1,0">
                <StackPanel Margin="6,12,6,0" Spacing="2">

                    <!-- Docker -->
                    <Grid>
                        <Rectangle Width="3" HorizontalAlignment="Left"
                                   Fill="#00bcd4" VerticalAlignment="Stretch"
                                   IsVisible="{Binding CurrentPageName,
                                               Converter={StaticResource StringEqualsConverter},
                                               ConverterParameter=Docker}" />
                        <Button Classes="NavBtn"
                                Content="Docker"
                                Command="{Binding NavigateToCommand}"
                                CommandParameter="Docker"
                                Margin="3,0,0,0" />
                    </Grid>

                    <!-- Services -->
                    <Grid>
                        <Rectangle Width="3" HorizontalAlignment="Left"
                                   Fill="#00bcd4" VerticalAlignment="Stretch"
                                   IsVisible="{Binding CurrentPageName,
                                               Converter={StaticResource StringEqualsConverter},
                                               ConverterParameter=Services}" />
                        <Button Classes="NavBtn"
                                Content="Services"
                                Command="{Binding NavigateToCommand}"
                                CommandParameter="Services"
                                Margin="3,0,0,0" />
                    </Grid>

                    <!-- WireGuard -->
                    <Grid>
                        <Rectangle Width="3" HorizontalAlignment="Left"
                                   Fill="#00bcd4" VerticalAlignment="Stretch"
                                   IsVisible="{Binding CurrentPageName,
                                               Converter={StaticResource StringEqualsConverter},
                                               ConverterParameter=WireGuard}" />
                        <Button Classes="NavBtn"
                                Content="WireGuard"
                                Command="{Binding NavigateToCommand}"
                                CommandParameter="WireGuard"
                                Margin="3,0,0,0" />
                    </Grid>

                    <!-- Ollama -->
                    <Grid>
                        <Rectangle Width="3" HorizontalAlignment="Left"
                                   Fill="#00bcd4" VerticalAlignment="Stretch"
                                   IsVisible="{Binding CurrentPageName,
                                               Converter={StaticResource StringEqualsConverter},
                                               ConverterParameter=Ollama}" />
                        <Button Classes="NavBtn"
                                Content="Ollama"
                                Command="{Binding NavigateToCommand}"
                                CommandParameter="Ollama"
                                Margin="3,0,0,0" />
                    </Grid>

                </StackPanel>
            </Border>

            <!-- ── Main content area ── -->
            <ContentControl Grid.Column="1"
                            Content="{Binding CurrentPage}"
                            Margin="0" />
        </Grid>
    </Grid>
</Window>
</file>

<file path="Views/MainWindow.axaml.cs">
using System.ComponentModel;
using Avalonia.Controls;
using MairiesHub.Controls;
using MairiesHub.ViewModels;

namespace MairiesHub.Views;

public partial class MainWindow : Window
{
    private SystemViewModel? _systemVm;

    public MainWindow()
    {
        InitializeComponent();
        DataContextChanged += OnDataContextChanged;
    }

    private void OnDataContextChanged(object? sender, System.EventArgs e)
    {
        if (_systemVm != null)
            _systemVm.PropertyChanged -= OnSystemVmPropertyChanged;

        if (DataContext is MainWindowViewModel vm)
        {
            _systemVm = vm.SystemVm;
            _systemVm.PropertyChanged += OnSystemVmPropertyChanged;
        }
    }

    private void OnSystemVmPropertyChanged(object? sender, PropertyChangedEventArgs e)
    {
        if (e.PropertyName == nameof(SystemViewModel.CpuPercent) && _systemVm != null)
        {
            var heartbeat = this.FindControl<EcgHeartbeatControl>("CpuHeartbeat");
            heartbeat?.AddSample(_systemVm.CpuPercent);
        }
    }
}
</file>

<file path="Views/OllamaView.axaml">
<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:MairiesHub.ViewModels"
             xmlns:models="using:MairiesHub.Models"
             x:Class="MairiesHub.Views.OllamaView"
             x:DataType="vm:OllamaViewModel">

    <Grid RowDefinitions="Auto,Auto,Auto,*" Margin="20,16,20,16">

        <!-- Header -->
        <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Margin="0,0,0,14">
            <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                <TextBlock Text="Ollama" FontSize="20" FontWeight="SemiBold" Foreground="#e0e0e0" />
                <Border CornerRadius="4" Padding="8,3" VerticalAlignment="Center">
                    <Border.Background>
                        <Binding Path="OllamaStatus"
                                 Converter="{StaticResource StateToColorConverter}" />
                    </Border.Background>
                    <TextBlock Text="{Binding OllamaStatus}"
                               FontSize="11"
                               Foreground="#ffffff"
                               FontWeight="SemiBold" />
                </Border>
            </StackPanel>
            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                <Ellipse Width="6" Height="6" Fill="#00bcd4" IsVisible="{Binding IsLoading}" />
                <TextBlock Text="Refreshing" FontSize="11" Foreground="#616161" IsVisible="{Binding IsLoading}" />
            </StackPanel>
        </Grid>

        <!-- Model count -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="6" Margin="0,0,0,16">
            <TextBlock Text="Models:" FontSize="13" Foreground="#757575" VerticalAlignment="Center" />
            <TextBlock Text="{Binding ModelCount}" FontSize="13" Foreground="#e0e0e0" VerticalAlignment="Center" />
        </StackPanel>

        <!-- Column headers -->
        <Grid Grid.Row="2"
              ColumnDefinitions="*,120"
              Margin="10,0,0,6">
            <TextBlock Grid.Column="0" Text="MODEL NAME" Classes="ColHeader" />
            <TextBlock Grid.Column="1" Text="SIZE"       Classes="ColHeader" />
        </Grid>

        <!-- Models list -->
        <ScrollViewer Grid.Row="3" VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding Models}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="models:OllamaModel">
                        <Border Classes="RowSep">
                            <Grid ColumnDefinitions="*,120" VerticalAlignment="Center">

                                <!-- Name -->
                                <TextBlock Grid.Column="0"
                                           Text="{Binding Name}"
                                           FontSize="13"
                                           Foreground="#e0e0e0"
                                           VerticalAlignment="Center" />

                                <!-- Size -->
                                <StackPanel Grid.Column="1"
                                            Orientation="Horizontal"
                                            Spacing="3"
                                            VerticalAlignment="Center">
                                    <TextBlock FontSize="13" Foreground="#e0e0e0">
                                        <TextBlock.Text>
                                            <Binding Path="SizeGb" StringFormat="{}{0:F1}" />
                                        </TextBlock.Text>
                                    </TextBlock>
                                    <TextBlock Text="GB" Classes="Muted" VerticalAlignment="Bottom" />
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- Empty state -->
        <TextBlock Grid.Row="3"
                   Text="No models found"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   Foreground="#424242"
                   FontSize="14"
                   IsVisible="{Binding !Models.Count}" />
    </Grid>
</UserControl>
</file>

